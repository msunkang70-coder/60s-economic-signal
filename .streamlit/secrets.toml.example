# .streamlit/secrets.toml.example
#
# ──────────────────────────────────────────────────────────────
# Streamlit Secrets 설정 가이드
# ──────────────────────────────────────────────────────────────
#
# [로컬 개발]
#   이 파일을 복사해서 .streamlit/secrets.toml 로 저장하고
#   실제 API 키를 입력하세요.
#   secrets.toml은 .gitignore에 포함돼 있어 GitHub에 올라가지 않습니다.
#
# [Streamlit Cloud 배포]
#   GitHub 리포지터리를 Streamlit Cloud에 연결한 뒤
#   App Settings > Secrets 탭에서 아래 내용을 그대로 붙여넣고
#   api_key 값만 실제 키로 교체하세요.
#   Streamlit Cloud 공식 문서: https://docs.streamlit.io/deploy/streamlit-community-cloud/deploy-your-app/secrets-management
#
# [ECOS API 키 발급]
#   한국은행 ECOS 오픈 API 포털: https://ecos.bok.or.kr
#   → 회원가입 → 오픈 API → 인증키 신청 (무료)
# ──────────────────────────────────────────────────────────────

[ecos]
api_key = "YOUR_ECOS_API_KEY_HERE"

# ──────────────────────────────────────────────────────────────
# Groq API 설정 (3줄 요약 LLM — 무료, 카드 불필요)
# ──────────────────────────────────────────────────────────────
# 키 발급: https://console.groq.com → API Keys → Create API Key
# 무료 한도: 분당 30회, 일 14,400회 (충분)
# 이 키가 없으면 규칙 기반 요약으로 자동 폴백됩니다.
# ──────────────────────────────────────────────────────────────

[groq]
api_key = "YOUR_GROQ_API_KEY_HERE"

# ──────────────────────────────────────────────────────────────
# 이메일 자동 발송 설정 (선택)
# ──────────────────────────────────────────────────────────────
# Streamlit 앱에서 "지금 발송" 버튼 기능을 쓰려면 아래를 입력하세요.
# GitHub Actions 자동 발송은 GitHub Secrets(Actions)에 별도 설정 필요.
#
# [Gmail 앱 비밀번호 발급]
#   Google 계정 → 보안 → 2단계 인증 활성화 →
#   앱 비밀번호 → 앱 선택(기타) → 생성 → 16자리 복사
#
# sender     : 발신자 Gmail 주소
# password   : Gmail 앱 비밀번호 (16자리, 공백 없이)
# recipients : 수신자 주소 — 쉼표로 구분 (여러 명 가능)
# smtp_host  : SMTP 서버 (기본: smtp.gmail.com, Naver: smtp.naver.com)
# smtp_port  : SMTP 포트 (기본: 587)
# ──────────────────────────────────────────────────────────────

[email]
sender     = "your_email@gmail.com"
password   = "your_app_password_here"
recipients = "recipient@example.com"
# smtp_host  = "smtp.gmail.com"   # 기본값 — 변경 불필요
# smtp_port  = 587                # 기본값 — 변경 불필요

# ──────────────────────────────────────────────────────────────
# 관리자 콘솔 접속 코드 (선택)
# ──────────────────────────────────────────────────────────────
# admin.py 관리자 페이지 접속 시 사용하는 코드입니다.
# 미설정 시 기본값(msion2026)이 사용됩니다.
# ──────────────────────────────────────────────────────────────

[admin]
code = "your_admin_code_here"

# ──────────────────────────────────────────────────────────────
# Slack 알림 설정 (선택)
# ──────────────────────────────────────────────────────────────
# 워치리스트 발동 시 Slack 채널로 알림을 보냅니다.
# Incoming Webhook URL 생성:
#   Slack App > Features > Incoming Webhooks > Add New Webhook
# ──────────────────────────────────────────────────────────────

# [slack]
# webhook_url = "https://hooks.slack.com/services/T.../B.../..."

# ──────────────────────────────────────────────────────────────
# 카카오 메시지 API 설정 (선택)
# ──────────────────────────────────────────────────────────────
# 워치리스트 발동 시 카카오톡 친구 메시지를 발송합니다.
#
# [카카오 설정 방법]
#   1. https://developers.kakao.com → 내 애플리케이션 → 앱 생성
#   2. 카카오 로그인 → 동의항목 → "친구 메시지" 동의
#   3. REST API 키로 OAuth2 인증 → Access Token 발급
#   4. /v1/api/talk/friends → 친구 UUID 목록 조회
#
# access_token   : OAuth2 Access Token
# receiver_uuids : 수신자 UUID 리스트 (카카오 친구 목록에서 조회)
# app_url        : 메시지 내 링크 URL (앱 URL)
# ──────────────────────────────────────────────────────────────

# [kakao]
# access_token   = "YOUR_KAKAO_ACCESS_TOKEN"
# receiver_uuids = ["uuid1", "uuid2"]
# app_url        = "https://your-app.streamlit.app"

# ──────────────────────────────────────────────────────────────
# Stripe 결제 연동 (선택)
# ──────────────────────────────────────────────────────────────
# 구독 결제를 위한 Stripe API 키입니다.
# 키 발급: https://dashboard.stripe.com/apikeys
# 테스트 모드 키(sk_test_...)를 먼저 사용하세요.
# 미설정 시 결제 기능이 비활성화되며 앱 동작에 영향 없습니다.
# ──────────────────────────────────────────────────────────────

# [stripe]
# secret_key       = "sk_test_YOUR_KEY_HERE"
# webhook_secret   = "whsec_YOUR_WEBHOOK_SECRET_HERE"
# price_id_basic   = "price_YOUR_BASIC_PRICE_ID"
# price_id_pro     = "price_YOUR_PRO_PRICE_ID"
